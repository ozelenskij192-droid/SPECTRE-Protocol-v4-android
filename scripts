extends CharacterBody3D

@export var speed := 5.0
@export var sprint_speed := 9.0
@export var crouch_speed := 2.5
@export var jump_velocity := 4.8
@export var sensitivity := 0.003
@export var health := 100
@export var ammo := 30
@export var reserve := 120

@onready var camera: Camera3D = $Camera3D
@onready var ray: RayCast3D = $Camera3D/ShootRay
@onready var gun_model: MeshInstance3D = $Camera3D/GunModel  # Реальная модель M4A1

var gravity = 9.81
var is_crouching = false
var is_aiming = false
var recoil = 0.0
var default_fov = 85.0
var aim_fov = 55.0

func _ready():
	Input.mouse_mode = Input.MOUSE_MODE_CAPTURED
	camera.fov = default_fov

func _input(event):
	if event is InputEventMouseMotion:
		rotate_y(-event.relative.x * sensitivity)
		camera.rotate_x(-event.relative.y * sensitivity)
		camera.rotation.x = clamp(camera.rotation.x, deg_to_rad(-89), deg_to_rad(89))
	
	if Input.is_action_just_pressed("shoot") and ammo > 0:
		shoot()
	if Input.is_action_just_pressed("reload") and reserve > 0:
		reload()
	if Input.is_action_just_pressed("crouch"):
		is_crouching = !is_crouching
	if Input.is_action_pressed("aim"):
		is_aiming = true
	else:
		is_aiming = false
	if Input.is_action_just_pressed("grenade"):
		throw_grenade()
	if Input.is_action_just_pressed("thermal"):
		toggle_thermal(!thermal_on)  # thermal_on - добавь переменную

func shoot():
	ammo -= 1
	recoil = 8.0
	gun_model.rotation.x -= 0.15  # Отдача на модели
	await get_tree().create_timer(0.05).timeout
	gun_model.rotation.x = 0.0
	if ray.is_colliding():
		var target = ray.get_collider()
		if target.is_in_group("enemy"):
			target.take_damage(45)

func reload():
	var need = 30 - ammo
	if need > 0 and reserve > 0:
		var take = min(need, reserve)
		ammo += take
		reserve -= take

func throw_grenade():
	var grenade = preload("res://scenes/grenade.tscn").instantiate()
	get_parent().add_child(grenade)
	grenade.global_position = global_position + Vector3(0, 1.5, 0)
	grenade.apply_central_impulse(-global_transform.basis.z * 25 + Vector3.UP * 8)

func toggle_thermal(on: bool):
	print("Thermal: ", on)  # Добавь шейдер на камеру для эффекта

func _physics_process(delta):
	if not is_on_floor():
		velocity.y -= gravity * delta
	if Input.is_action_just_pressed("jump") and is_on_floor():
		velocity.y = jump_velocity
	
	var input_dir = Input.get_vector("left", "right", "forward", "back")
	var direction = (transform.basis * Vector3(input_dir.x, 0, input_dir.y)).normalized()
	var current_speed = sprint_speed if Input.is_action_pressed("sprint") else (crouch_speed if is_crouching else speed)
	velocity.x = direction.x * current_speed
	velocity.z = direction.z * current_speed
	
	move_and_slide()
	
	camera.fov = lerp(camera.fov, aim_fov if is_aiming else default_fov, 12 * delta)
	camera.rotation.x -= recoil * delta * 2
	recoil = lerp(recoil, 0.0, 15 * delta)
	
	if velocity.length() > 1.0 and is_on_floor():
		camera.position.y = sin(Time.get_ticks_msec() * 0.01) * 0.03  # Headbob
